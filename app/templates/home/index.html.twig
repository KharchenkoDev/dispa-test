{% extends 'base.html.twig' %}

{% block title %}Проверка ИНН{% endblock %}

{% block stylesheets %}
<style>
    *, *::before, *::after { box-sizing: border-box; }

    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #f5f6fa;
        color: #2d3436;
        margin: 0;
        padding: 24px;
    }

    h1 {
        font-size: 1.4rem;
        font-weight: 600;
        margin: 0 0 4px;
    }

    .subtitle {
        color: #636e72;
        font-size: .875rem;
        margin: 0 0 24px;
    }

    .card {
        background: #fff;
        border-radius: 8px;
        box-shadow: 0 1px 3px rgba(0,0,0,.08);
        overflow: hidden;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: .875rem;
    }

    thead th {
        background: #f8f9fb;
        padding: 12px 16px;
        text-align: left;
        font-weight: 600;
        font-size: .75rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #636e72;
        border-bottom: 1px solid #e8ecef;
        white-space: nowrap;
    }

    tbody td {
        padding: 12px 16px;
        border-bottom: 1px solid #f0f2f5;
        vertical-align: middle;
    }

    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: #fafbfc; }

    .badge {
        display: inline-block;
        padding: 2px 10px;
        border-radius: 999px;
        font-size: .75rem;
        font-weight: 500;
    }

    .badge-active   { background: #d4f5e9; color: #00875a; }
    .badge-inactive { background: #ffe8e8; color: #c0392b; }

    .okved-code { font-family: monospace; color: #636e72; }

    .empty {
        text-align: center;
        padding: 64px 24px;
        color: #b2bec3;
    }

    .pagination {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 16px;
        border-top: 1px solid #e8ecef;
        font-size: .875rem;
        color: #636e72;
    }

    .pagination-links { display: flex; gap: 4px; }

    .pagination-links a,
    .pagination-links span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 32px;
        height: 32px;
        padding: 0 6px;
        border-radius: 6px;
        text-decoration: none;
        color: #2d3436;
        border: 1px solid #e8ecef;
        transition: background .15s;
    }

    .pagination-links a:hover { background: #f5f6fa; }

    .pagination-links span.current {
        background: #2d3436;
        color: #fff;
        border-color: #2d3436;
        font-weight: 600;
    }

    .pagination-links span.disabled {
        color: #b2bec3;
        pointer-events: none;
    }
</style>
{% endblock %}

{% block body %}
<h1>Проверка ИНН</h1>
<p class="subtitle">Всего записей: {{ total }}. Для запроса используйте <code>/api/inn/{inn}</code>.</p>

<div class="card">
    {% if items is empty %}
        <div class="empty">Нет данных.</div>
    {% else %}
        <table>
            <thead>
                <tr>
                    <th>ИНН</th>
                    <th>Организация</th>
                    <th>Статус</th>
                    <th>ОКВЭД</th>
                    <th>Дата запроса</th>
                </tr>
            </thead>
            <tbody>
                {% for item in items %}
                <tr>
                    <td><code>{{ item.inn }}</code></td>
                    <td>{{ item.name }}</td>
                    <td>
                        {% if item.active %}
                            <span class="badge badge-active">Активна</span>
                        {% else %}
                            <span class="badge badge-inactive">Не активна</span>
                        {% endif %}
                    </td>
                    <td><span class="okved-code">{{ item.okved ?: '—' }}</span></td>
                    <td>{{ item.createdAt|date('d.m.Y H:i') }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        {% if pages > 1 %}
        <div class="pagination">
            <span>Страница {{ page }} из {{ pages }}</span>
            <div class="pagination-links">
                {% if page > 1 %}
                    <a href="?page=1">«</a>
                    <a href="?page={{ page - 1 }}">‹</a>
                {% else %}
                    <span class="disabled">«</span>
                    <span class="disabled">‹</span>
                {% endif %}

                {% for p in max(1, page - 2)..min(pages, page + 2) %}
                    {% if p == page %}
                        <span class="current">{{ p }}</span>
                    {% else %}
                        <a href="?page={{ p }}">{{ p }}</a>
                    {% endif %}
                {% endfor %}

                {% if page < pages %}
                    <a href="?page={{ page + 1 }}">›</a>
                    <a href="?page={{ pages }}">»</a>
                {% else %}
                    <span class="disabled">›</span>
                    <span class="disabled">»</span>
                {% endif %}
            </div>
        </div>
        {% endif %}
    {% endif %}
</div>
{% endblock %}
